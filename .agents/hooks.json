{
  "repo-command-guard": {
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./.agents/hooks/command_guard.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "repo-invocation-reminder": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "python3 ./.agents/hooks/invocation_reminder.py",
        "timeout": 10
      }
    ]
  }
}
